# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="Enterprise Backend"
NODE_ENV=development
APP_PORT=3000
API_PREFIX=api
API_VERSION=v1
FRONTEND_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/enterprise_db?schema=public"
DATABASE_LOGGING=false

# ─── Authentication ──────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-me
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-me
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
EMAIL_VERIFICATION_ENABLED=false
PASSWORD_RESET_TOKEN_EXPIRES_IN=3600

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=300
REDIS_KEY_PREFIX=enterprise:

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_ENABLED=false
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM="Enterprise App <noreply@enterprise.com>"

# ─── Queue ────────────────────────────────────────────────────────────────────
QUEUE_ENABLED=false
QUEUE_REMOVE_ON_COMPLETE=100
QUEUE_REMOVE_ON_FAIL=50
QUEUE_DEFAULT_ATTEMPTS=3

# ─── Monitoring ──────────────────────────────────────────────────────────────
MONITORING_ENABLED=false
MONITORING_PROVIDER=none
DATADOG_API_KEY=
SENTRY_DSN=
METRICS_PORT=9090

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
